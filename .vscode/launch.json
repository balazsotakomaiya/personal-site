{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js / Bun: Dev",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["next", "dev"],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Next.js / Bun: Build & Start",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["next", "build"],
      "console": "integratedTerminal",
      "preLaunchTask": "bun-next-start",
      "postDebugTask": "bun-next-stop",
      "env": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "Next.js / Bun: Start only",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["next", "start"],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
